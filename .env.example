# Copy this file to ".env" and fill in the real values.
# ".env" (without .example) is never committed to GitHub -- it's already in .gitignore.

# Key the HappyRobot workflow must send in the X-API-Key header
# to be able to use this backend. Make up any long, random string.
API_KEY=replace-this-with-a-long-random-key

# Your FMCSA WebKey (obtained from the 1Password link you were sent).
FMCSA_WEBKEY=
